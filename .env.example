# =============================================
# Hospital Capilar Platform - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# =============================================
# PostHog Analytics
# =============================================
# Get your API key from: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_project_api_key_here

# PostHog host (EU or US)
# EU: https://eu.i.posthog.com
# US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# =============================================
# PostHog API (for Dashboard - optional)
# =============================================
# Personal API key for accessing PostHog API
# Get it from: https://app.posthog.com/me/settings
VITE_POSTHOG_PROJECT_API_KEY=phx_your_personal_api_key_here

# Your PostHog project ID (number from URL)
VITE_POSTHOG_PROJECT_ID=12345

# =============================================
# Resend (transactional email)
# =============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# =============================================
# Firebase (optional - for storing leads)
# =============================================
# Get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================
# Firebase Admin (for Netlify Functions)
# =============================================
# Service account JSON string — download from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# =============================================
# GoHighLevel CRM
# =============================================
VITE_GHL_API_KEY=your_ghl_api_key
VITE_GHL_LOCATION_ID=U4SBRYIlQtGBDHLFwEUf

# =============================================
# Stripe Payments
# =============================================
STRIPE_RK_KEY=rk_live_your_stripe_restricted_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================
# Koibox (Clinic Booking)
# =============================================
KOIBOX_API_KEY=your_koibox_api_key

# =============================================
# Google Ads API (for ad spend sync)
# =============================================
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CUSTOMER_ID=5559727380
GOOGLE_ADS_MCC_ID=5915365707

# =============================================
# Meta Ads API (for ad spend sync + Conversions API)
# =============================================
# System User token with permissions: ads_management + business_management
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=act_your_account_id

# Meta Pixel / Dataset ID associated with diagnostico.hospitalcapilar.com
# Used by Conversions API (server-side conversion forwarding to bypass browser pixel restrictions)
# Get from: Meta Business Manager → Events Manager → Pixel/Dataset settings
META_PIXEL_ID=your_pixel_id

# =============================================
# Alerting
# =============================================
# Email to receive system alerts (failures, health check issues)
ALERT_EMAIL=philipe@growth4u.io
